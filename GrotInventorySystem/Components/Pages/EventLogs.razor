@page "/event-logs"

@using Microsoft.EntityFrameworkCore
@using GrotInventorySystem.Data
@using GrotInventorySystem.Domain.Entities
@using GrotInventorySystem.Domain.ViewModels

@inject ApplicationDbContext Db

<h3>Rejestr zdarzeń</h3>

@if (LogsList.Count == 0)
{
    <p><b>Brak zdarzeń!</b></p>
}
else
{
    <table>
        <thead>
            <tr>
                <th>Data i godzina</th>
                <th>Akcja</th>
                <th>Użytkownik</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in LogsList)
            {
                <tr>
                    <td>@log.Created</td>
                    <td>@log.Action</td>
                    <td>@log.UserEmail</td>
                </tr>
            }
        </tbody>

    </table>
}

@code {
    private List<EventLogViewModel> LogsList { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        var logs = await Db.EventLogs
            .OrderByDescending(l => l.Created)
            .ToListAsync();

        var userIds = logs
            .Where(l => l.UserId.HasValue)
            .Select(l => l.UserId.ToString())
            .Distinct()
            .ToList();

        var users = await Db.Users
            .Where(u => userIds.Contains(u.Id))
            .ToDictionaryAsync(u => u.Id, u => u.Email);

        LogsList = logs.Select(l => new EventLogViewModel
        {
            Created = l.Created,
            Action = l.Action,
            UserEmail = l.UserId.HasValue && users.TryGetValue(l.UserId.ToString()!, out var email)
                ? email
                : "nieznany"
        }).ToList();
    }

}