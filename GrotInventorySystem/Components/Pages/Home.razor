@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>GROT — Panel Główny</PageTitle>

<div class="container-fluid py-4">

    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white border-0 shadow">
                <div class="card-body py-4 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-shield-fill" style="font-size: 3rem;"></i>
                        <div>
                            <h1 class="mb-1 fw-bold">System Ewidencji Broni GROT</h1>
                            <p class="mb-0 text-secondary">
                                Wojskowy system zarządzania bronią i modułami
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-bullseye text-dark" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title fw-bold">Broń</h5>
                    <p class="card-text text-muted">
                        Zarządzaj ewidencją broni, dodawaj nowe egzemplarze, przeglądaj historię.
                    </p>
                    <a href="/weapons" class="btn btn-dark mt-2">
                        Przejdź do broni
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-tools text-dark" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title fw-bold">Moduły</h5>
                    <p class="card-text text-muted">
                        Przeglądaj moduły, montuj i demontuj na broni.
                    </p>
                    <a href="/modules" class="btn btn-dark mt-2">
                        Przejdź do modułów
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-file-earmark-text text-dark" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title fw-bold">Dokumenty</h5>
                    <p class="card-text text-muted">
                        Wydania i przyjęcia broni — pełna historia ruchów.
                    </p>
                    <a href="/movement-documents" class="btn btn-dark mt-2">
                        Przejdź do dokumentów
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="row g-3">

        <div class="col-md-6">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-bar-chart text-dark" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title fw-bold">Raporty</h5>
                    <p class="card-text text-muted">
                        Stan magazynu, statystyki, wydruki raportów.
                    </p>
                    <a href="/reports" class="btn btn-dark mt-2">
                        Przejdź do raportów
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow h-100">
                <div class="card-body text-center py-4">
                    <i class="bi bi-clipboard-data text-dark" style="font-size: 2.5rem;"></i>
                    <h5 class="card-title fw-bold">Rejestr zdarzeń</h5>
                    <p class="card-text text-muted">
                        Historia wszystkich operacji wykonanych w systemie.
                    </p>
                    <a href="/event-log" class="btn btn-dark mt-2">
                        Przejdź do rejestru
                    </a>
                </div>
            </div>
        </div>

    </div>

</div>